VK_GROUP_TOKEN=vk1.a.YOUR_GROUP_TOKEN
VK_CALLBACK_CONFIRMATION=YOUR_CONFIRMATION_STRING
VK_CALLBACK_SECRET=YOUR_RANDOM_SECRET
VK_API_VERSION=5.199

SUPABASE_URL=https://hcefoztytkfskmdchqos.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY
# Если service-role временно не задан, бот умеет читать fallback ниже для AI-памяти.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

OWNER_VK_ID=628466808

REPORTS_PEER_ID=
STAFF_PEER_ID=
NOTIFY_PEER_ID=

CLEANUP_MESSAGES_AFTER_REPORT=true
REPORT_PROOFS_BUCKET=

# VK chat real actions
VK_USE_CHAT_RESTRICTIONS=true
VK_AUTO_KICK_ON_BAN=true
VK_STICKY_BANS=true
REPORTS_STRICT_MODE=true
CANDIDATES_INVITE_LINK=https://vk.me/join/YOUR_CANDIDATES_CHAT_INVITE

DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=220
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_TIMEOUT_MS=16000
AI_MAX_OUTPUT_CHARS=650

# Gemini AI. Если GEMINI_API_KEY задан, бот использует Gemini вместо DeepSeek.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_MAX_TOKENS=360
GEMINI_TEMPERATURE=0.65
GEMINI_TIMEOUT_MS=18000
AI_HISTORY_LIMIT=8
AI_ATMOSPHERE_ENABLED=true
AI_ATMOSPHERE_CHANCE=0.025
AI_PASSIVE_REPLY_MODE=smart
AI_STAFF_REPLY_ALL=false
AI_ATMOSPHERE_PEER_IDS=
AI_ATMOSPHERE_MAX_CHATS=3
AI_CRON_SECRET=
AI_IMAGES_BUCKET=vk-ai-images

TABLE_WEBHOOK_SECRET=YOUR_TABLE_WEBHOOK_SECRET
APPLICATION_REPORT_EMAILS=GOSS_PROFILE,MOD_APPLICATION,APPLICATION,INACTIVE_REQ
APPLICATION_TABLES=reports,admin_logs

# Старый режим авто-уведомлений Google Form → VK. Можно оставить пустым, если используешь только /заявки.
GOOGLE_SHEET_WEBHOOK_SECRET=YOUR_GOOGLE_SHEET_SECRET
GOOGLE_SHEET_TARGET_NAME=Ответы на форму (3)

# Новый стабильный режим: /заявки сам забирает строки из Google Sheet.
# Это URL Web App из Apps Script Deploy → Web app.
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GOOGLE_SHEET_PULL_SECRET=YOUR_GOOGLE_SHEET_SECRET
GOOGLE_SHEET_STAFF_SECRET=YOUR_GOOGLE_SHEET_SECRET

# Google Sheets pull mode v8
# Должен быть URL Apps Script Web App, НЕ Vercel webhook.
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GOOGLE_SHEET_PULL_SECRET=change_me
GOOGLE_SHEET_TARGET_NAME=Ответы на форму (3)
